---
import { useTranslations } from '../i18n/utils';
export interface Props { locale?: string; }
const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container-1078 footer-inner">
    <p class="tagline">{t('footer.tagline')}</p>
    <p class="copy">© {year} Guardino Technologies LLC. {t('footer.rights')}</p>
  </div>
</footer>
<style>
  .site-footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 48px 0; margin-top: 96px; }
  .footer-inner { display: flex; flex-direction: column; gap: 12px; align-items: center; text-align: center; }
  .tagline { color: #6d6d6d; font-size: 14px; }
  .copy { color: #636363; font-size: 12px; }
</style>
