---
import '../styles/global.css';
export interface Props {
  title: string;
  description: string;
  locale?: string;
  canonicalURL?: string;
  isHome?: boolean;
}
const { title, description, locale = 'en', canonicalURL, isHome = false } = Astro.props;
const siteURL = 'https://guardinotechnologies.com';
const canonical = canonicalURL ?? new URL(Astro.url.pathname, siteURL).href;
const dir = locale === 'ar' ? 'rtl' : 'ltr';
const allLocales = ['en', 'tr', 'de', 'fr', 'ar'];
const cleanPath = Astro.url.pathname.replace(/^\/(tr|de|fr|ar)/, '') || '/';
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Guardino Technologies',
  url: siteURL,
  logo: `${siteURL}/og-default.svg`,
  description: 'Enterprise-grade DNS security and cognitive protection.',
  address: { '@type': 'PostalAddress', addressLocality: 'Istanbul', addressCountry: 'TR' },
};
---
<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {allLocales.map((l) => (
      <link rel="alternate" hreflang={l} href={l === 'en' ? `${siteURL}${cleanPath}` : `${siteURL}/${l}${cleanPath === '/' ? '' : cleanPath}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteURL}${cleanPath}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}/og-default.svg`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteURL}/og-default.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Raleway:wght@400;600&display=swap" rel="stylesheet" />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />}
  </head>
  <body>
    <slot />
  </body>
</html>
