---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { useTranslations, locales } from '../../i18n/utils';
export const prerender = true;
export function getStaticPaths() {
  return locales.filter((l) => l !== 'en').map((l) => ({ params: { locale: l } }));
}
const { locale } = Astro.params;
const t = useTranslations(locale!);
---
<MarketingLayout title={t('meta.contact.title')} description={t('meta.home.desc')} locale={locale}>
  <section class="container-1078 contact-hero">
    <h1>{t('contact.title')}</h1>
  </section>
  <section class="container-1078 form-section">
    <ContactForm locale={locale} />
  </section>
</MarketingLayout>
<style>
  .contact-hero { padding: 120px 24px 32px; text-align: center; }
  .contact-hero h1 { font-size: 54px; font-weight: 300; }
  .form-section { padding: 32px 24px 96px; }
</style>
