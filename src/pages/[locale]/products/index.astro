---
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { useTranslations, locales } from '../../../i18n/utils';
export const prerender = true;
export function getStaticPaths() {
  return locales.filter((l) => l !== 'en').map((l) => ({ params: { locale: l } }));
}
const { locale } = Astro.params;
const t = useTranslations(locale!);
---
<MarketingLayout title={t('meta.products.title')} description={t('meta.home.desc')} locale={locale}>
  <section class="container-1078 section">
    <h1>{t('products.title')}</h1>
    <ProductCard title={t('products.guardinoAi.title')} description={t('products.guardinoAi.desc')} href={`/${locale}/contact`} />
  </section>
</MarketingLayout>
<style>
  .section { padding: 120px 24px 96px; }
  .section h1 { font-size: 54px; font-weight: 300; margin-bottom: 48px; }
</style>
