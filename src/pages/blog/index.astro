---
import { getCollection } from 'astro:content';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<MarketingLayout title="Blog — Guardino Technologies" description="Insights on DNS security and digital infrastructure.">
  <section class="container-1078 section">
    <h1>Blog</h1>
    <ul class="post-list">
      {posts.map((p) => (
        <li class="post-item glass-card">
          <a href={`/blog/${p.id}`}>
            <p class="date">{p.data.pubDate.toISOString().slice(0, 10)}</p>
            <h2>{p.data.title}</h2>
            <p class="desc">{p.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</MarketingLayout>
<style>
  .section { padding: 120px 24px 96px; }
  .section h1 { font-size: 54px; font-weight: 300; margin-bottom: 48px; }
  .post-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .post-item a { display: block; padding: 28px; text-decoration: none; color: #fff; }
  .date { color: #6d6d6d; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
  .post-item h2 { font-size: 24px; font-weight: 600; margin-bottom: 8px; }
  .desc { color: #6d6d6d; font-size: 15px; line-height: 1.5; }
</style>
