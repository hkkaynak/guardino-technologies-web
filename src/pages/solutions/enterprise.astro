---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CTABand from '../../components/CTABand.astro';
const pains = [
  { p: 'DNS-layer attacks bypass perimeter firewalls.', a: 'guardino.ai blocks at the resolver — before traffic reaches your network.' },
  { p: 'Compliance vendors demand intrusive logging.', a: 'We are zero-log by default. Data residency in Türkiye, EU, or US.' },
  { p: 'AD / Entra ID integration is a multi-quarter project.', a: 'Native SAML & SCIM. Onboard 5,000 users in an afternoon.' },
  { p: 'Threat intel feeds expire fast.', a: 'Continuous updates from our global research network.' },
];
---
<MarketingLayout title="Enterprise — Guardino Technologies" description="Enterprise DNS security without surveillance.">
  <section class="container-1078 hero">
    <h1>Enterprise Security Without the Surveillance Tax.</h1>
    <p class="lead">99.99% SLA. SAML/SCIM. SIEM/SOAR integrations. Dedicated support engineering.</p>
  </section>
  <section class="container-1078 section">
    <h2>Pain → Answer</h2>
    <div class="pa-grid">
      {pains.map((x) => (
        <div class="pa">
          <p class="p">{x.p}</p>
          <p class="a">→ {x.a}</p>
        </div>
      ))}
    </div>
  </section>
  <CTABand title="Request an Enterprise Demo." ctaText="Contact Sales" />
</MarketingLayout>
<style>
  .hero { padding: 120px 24px 32px; }
  .hero h1 { font-size: clamp(32px, 5vw, 54px); font-weight: 300; margin-bottom: 24px; line-height: 1.1; }
  .lead { color: #6d6d6d; font-size: 18px; max-width: 640px; line-height: 1.6; }
  .section { padding: 64px 24px; }
  .section h2 { font-size: 32px; font-weight: 300; margin-bottom: 32px; }
  .pa-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  .pa { padding: 24px; border-left: 2px solid rgba(160,224,171,0.4); }
  .p { color: #6d6d6d; font-size: 16px; margin-bottom: 8px; }
  .a { color: #fff; font-size: 16px; }
</style>
