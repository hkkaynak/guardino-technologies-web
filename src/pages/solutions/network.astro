---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CTABand from '../../components/CTABand.astro';
---
<MarketingLayout title="Network / ISP — Guardino Technologies" description="ISP-grade DNS filtering with sovereign data flow.">
  <section class="container-1078 hero">
    <h1>ISP-Grade Filtering. Without the Surveillance.</h1>
    <p class="lead">Deploy on-prem or in our sovereign cloud. Per-subscriber RPZ policies. RIPE-grade peering.</p>
  </section>
  <CTABand title="Talk to our network architects." ctaText="Contact Sales" />
</MarketingLayout>
<style>
  .hero { padding: 120px 24px 96px; }
  .hero h1 { font-size: clamp(32px, 5vw, 54px); font-weight: 300; margin-bottom: 24px; line-height: 1.1; }
  .lead { color: #6d6d6d; font-size: 18px; max-width: 640px; line-height: 1.6; }
</style>
